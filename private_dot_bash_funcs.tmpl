# .bash_funcs

function path() {
    echo "PATH="
    echo -e "    ${PATH//:/\\n    }"
}

function pypath() {
    echo "PYTHONPATH="
    if [[ ! -z "${PYTHONPATH}" ]]; then
        echo -e "    ${PYTHONPATH//:/\\n    }"
    fi
}

