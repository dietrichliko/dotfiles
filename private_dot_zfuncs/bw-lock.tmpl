# shellcheck shell=zsh
#
# ~/.zfuncs/bw-lock
#
# Manual lock function - locks vault and clears session
bw-lock() {
    # Lock the vault
    if bw lock 2>/dev/null; then
        echo "Bitwarden vault locked"
    fi
    
{{ if eq .chezmoi.os "darwin" }}
    # macOS: Clear from keychain
    if security delete-generic-password -a "$USER" -s "bw_session_${USER}" 2>/dev/null; then
        echo "Session cleared from keychain"
    fi
{{ else if eq .location "desktop" "Desktop" }}
    # Desktop Linux: Clear from GNOME keyring
    if secret-tool clear user "$USER" key "bw_session_${USER}" 2>/dev/null; then
        echo "Session cleared from GNOME keyring"
    fi
{{ else }}
    # Server: Clear from kernel keyring
    KEYID=$(keyctl search @s user "bw_session_${USER}" 2>/dev/null) && {
        if keyctl unlink "$KEYID" @s 2>/dev/null; then
            echo "Session cleared from kernel keyring"
        fi
    }
{{ end }}
    
    # Also unset environment variable in current shell
    unset BW_SESSION
}
