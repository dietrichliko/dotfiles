# .bash_profile
# DO NOT EDIT - file is controlled by chezmoi

{{ if eq .chezmoi.os "darwin" }}
/usr/bin/ssh-add --apple-load-keychain 2>/dev/null
{{ end -}}

{{ if eq .location "clip" }}
ml add build-env/f2022 git/2.42.0-gcccore-13.2.0 &>/dev/null
{{ end -}}

{{ if eq .chezmoi.os "darwin" }}
export PATH="$HOME/.local/bin:/opt/local/bin:/opt/local/sbin:$PATH"
{{ else }}
export PATH="$HOME/.local/bin:$PATH"
{{ end -}}

# Source ~/.bashrc only for interactive shells
if [[ $- == *i* ]]; then
    if [ -f ~/.bashrc ]; then
        source ~/.bashrc
    fi
fi

