{{- if hasPrefix "/afs/" .chezmoi.homeDir -}}
#!/bin/sh

LOGDIR="$HOME"
HOSTNAME=$(hostname -s)
LOGFILE="$LOGDIR/.krenew_${HOSTNAME}.log"

log() {
    printf '%s: %s\n' "$(date '+%F %T')" "$*" >> "$LOGFILE"
}

# Exit silently if home is not writable
if [ ! -w "$LOGDIR" ]; then
    exit 0
fi

# Only proceed if krenew exists
if ! command -v krenew >/dev/null 2>&1; then
    exit 0
fi

# Start only one krenew per user on this node
if ! pgrep -u "$USER" -f "krenew -K" >/dev/null 2>&1; then

    log "Starting krenew"

    # Optional: warn if ticket is not renewable
    if command -v klist >/dev/null 2>&1; then
        if ! klist -f 2>/dev/null | grep -q "R"; then
            log "Warning: Ticket is not renewable"
        fi
    fi

    # Start krenew in background
    krenew -K 30 -v >> "$LOGFILE" 2>&1 &
    log "krenew started"
fi

# Keep only last 7 logs (safe cleanup)
ls -1t "$LOGDIR"/.krenew_*.log 2>/dev/null | tail -n +8 | xargs -r rm --

exit 0
{{- end -}}

